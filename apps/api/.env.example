DATABASE_URL="postgresql://user:password@localhost:5432/p2p_iraq"
PORT=3001
NODE_ENV=development

# Telegram Bot (for sending notifications)
BOT_TOKEN=your_bot_token_here
ADMIN_GROUP_ID=-100xxxxxxxxx

# Escrow wallet addresses
ESCROW_WALLET_TRC20=your_trc20_address
ESCROW_WALLET_ERC20=your_erc20_address
ESCROW_WALLET_BEP20=your_bep20_address

# Cloudflare R2 (proof storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=p2p-proofs
R2_PUBLIC_URL=

# Rate (manual — updated via admin panel)
INITIAL_BUY_RATE=1485
INITIAL_SELL_RATE=1465
