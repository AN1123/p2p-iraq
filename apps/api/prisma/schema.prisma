generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  telegramId        BigInt    @unique @map("telegram_id")
  telegramUsername  String?   @map("telegram_username") @db.VarChar(64)
  fullName          String?   @map("full_name") @db.VarChar(128)
  phone             String?   @db.VarChar(20)
  governorate       String?   @db.VarChar(32)
  trustLevel        String    @default("new") @map("trust_level") @db.VarChar(16)
  kycStatus         String    @default("none") @map("kyc_status") @db.VarChar(16)
  kycIdImage        String?   @map("kyc_id_image")
  isBanned          Boolean   @default(false) @map("is_banned")
  dailyLimitUsd     Decimal   @default(100) @map("daily_limit_usd") @db.Decimal(10, 2)
  createdAt         DateTime  @default(now()) @map("created_at")
  lastActive        DateTime? @map("last_active")

  orders            Order[]   @relation("UserOrders")
  assignedOrders    Order[]   @relation("AdminOrders")
  auditLogs         AuditLog[]
  disputes          Dispute[]

  @@map("users")
}

model Order {
  id              String    @id @default(uuid())
  orderRef        String    @unique @map("order_ref") @db.VarChar(32)
  type            String    @db.VarChar(4)   // BUY / SELL
  userId          String    @map("user_id")
  amountUsdt      Decimal   @map("amount_usdt") @db.Decimal(12, 2)
  amountIqd       Decimal?  @map("amount_iqd") @db.Decimal(15, 0)
  network         String    @db.VarChar(16)
  paymentMethod   String    @map("payment_method") @db.VarChar(16)
  walletAddress   String?   @map("wallet_address")
  localAccount    String?   @map("local_account")
  governorate     String?   @db.VarChar(32)
  commissionPct   Decimal   @default(1.00) @map("commission_pct") @db.Decimal(5, 2)
  commissionIqd   Decimal?  @map("commission_iqd") @db.Decimal(15, 0)
  rateIqd         Decimal?  @map("rate_iqd") @db.Decimal(10, 0)
  status          String    @default("pending") @db.VarChar(32)
  assignedAdminId String?   @map("assigned_admin_id")
  escrowTxHash    String?   @map("escrow_tx_hash")
  releaseTxHash   String?   @map("release_tx_hash")
  proofUrl        String?   @map("proof_url")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")
  expiresAt       DateTime  @map("expires_at")

  user            User      @relation("UserOrders", fields: [userId], references: [id])
  admin           User?     @relation("AdminOrders", fields: [assignedAdminId], references: [id])
  auditLogs       AuditLog[]
  disputes        Dispute[]

  @@map("orders")
}

model Offer {
  id              String    @id @default(uuid())
  traderId        String    @map("trader_id")
  type            String    @db.VarChar(4)
  amountUsdt      Decimal   @map("amount_usdt") @db.Decimal(12, 2)
  minAmount       Decimal   @default(50) @map("min_amount") @db.Decimal(12, 2)
  maxAmount       Decimal?  @map("max_amount") @db.Decimal(12, 2)
  rateIqd         Decimal   @map("rate_iqd") @db.Decimal(10, 0)
  paymentMethods  String[]  @map("payment_methods")
  governorates    String[]
  isActive        Boolean   @default(true) @map("is_active")
  filledAmount    Decimal   @default(0) @map("filled_amount") @db.Decimal(12, 2)
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")

  @@map("offers")
}

model Dispute {
  id            String    @id @default(uuid())
  orderId       String    @map("order_id")
  raisedBy      String    @map("raised_by")
  reason        String
  evidenceUrls  String[]  @map("evidence_urls")
  status        String    @default("open") @db.VarChar(16)
  resolution    String?
  resolvedBy    String?   @map("resolved_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")
  slaDeadline   DateTime  @map("sla_deadline")

  order         Order     @relation(fields: [orderId], references: [id])
  raiser        User      @relation(fields: [raisedBy], references: [id])

  @@map("disputes")
}

model AuditLog {
  id          String    @id @default(uuid())
  orderId     String?   @map("order_id")
  userId      String?   @map("user_id")
  action      String    @db.VarChar(64)
  performedBy String?   @map("performed_by")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  details     Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  order       Order?    @relation(fields: [orderId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Rate {
  id        String   @id @default(uuid())
  buyRate   Decimal  @map("buy_rate") @db.Decimal(10, 0)
  sellRate  Decimal  @map("sell_rate") @db.Decimal(10, 0)
  setBy     String?  @map("set_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("rates")
}
